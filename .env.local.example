# Copy this file for each new site clone:
#   cp .env.local.example .env.local
#
# Never commit .env.local (gitignored).
# Setup guides: docs/NEW-CLIENT.md (Integrations) · docs/recaptcha.md · docs/resend-setup.md
#
# Agency setup: ONE Google Cloud project for all client sites.
#   - RECAPTCHA_PROJECT_ID + RECAPTCHA_API_KEY_SECRET → same on every clone
#   - NEXT_PUBLIC_RECAPTCHA_SITE_KEY → per client (or same if one key lists all domains)

# --- reCAPTCHA Enterprise (optional — leave blank to disable verification) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_PROJECT_ID=
# Secret key (6Le...) OR Cloud API key (AIzaSy...) — usually same across all clones
RECAPTCHA_API_KEY_SECRET=

# --- Contact email via Resend — docs/resend-setup.md ---
RESEND_API_KEY=
# Optional — defaults to siteConfig.email in config/site.ts
# CONTACT_LEAD_TO=
# Optional — defaults to "{site name} <onboarding@resend.dev>" until domain is verified
# CONTACT_LEAD_FROM=LifeSpring Design <contact@lifespringdesign.com>

# --- Future integrations ---
# LIFESPRING_HUB_API_URL=
# LIFESPRING_HUB_API_KEY=
